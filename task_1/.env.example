# API Configuration
# 将此文件复制为 .env 并填入实际值

# 学校deepseek (School DeepSeek)
API_KEY=your_api_key_here
MODEL_NAME=DeepSeek-R1-Int8
API_URL=https://deepseek.fosu.edu.cn/api/chat/completions

# 硅基流动deepseek (SiliconFlow DeepSeek) - Uncomment to use
# API_KEY=your_siliconflow_key_here
# MODEL_NAME=deepseek-ai/DeepSeek-R1-Distill-Qwen-14B
# API_URL=https://api.siliconflow.cn/v1/chat/completions

# Other configurations
HF_TOKEN=your_huggingface_token_if_needed
